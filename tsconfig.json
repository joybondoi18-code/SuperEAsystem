{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],

    "allowJs": true,
    "checkJs": false,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": false,
    "forceConsistentCasingInFileNames": true,

    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,

    "paths": {
      "@/*": ["./*"],
      "@crypto/*": ["./crypto/*"]
    },

    "plugins": [{ "name": "next" }]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",

    "**/*.js",
    "**/*.jsx",

    ".next/types/**/*.ts",

    "app/api/admin/forex-command/route.ts",

    "crypto/**/*"
  ],

  "exclude": ["node_modules"]
}
