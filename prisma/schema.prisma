generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  password             String
  role                 Role          @default(USER)
  referralCode         String        @unique
  referredBy           String?
  isActive             Boolean       @default(false)
  planExpiresAt        DateTime?
  balance              Float         @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  binanceApiKey        String?
  binanceSecretKey     String?
  packageType          PackageType?
  vpsId                String?
  approvedTransactions Transaction[] @relation("AdminApproval")
  transactions         Transaction[]
}

model Transaction {
  id          String       @id @default(cuid())
  userId      String
  type        String
  amount      Float
  method      String
  status      String
  refUserId   String?
  txHash      String?
  createdAt   DateTime     @default(now())
  qrcodeUrl   String?
  approvedAt  DateTime?
  paidAt      DateTime?
  paymentRef  String?
  accountInfo String?
  adminId     String?
  packageType PackageType?
  admin       User?        @relation("AdminApproval", fields: [adminId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
}

model BotSetting {
  id         String   @id @default(cuid())
  isRunning  Boolean  @default(false)
  lastToggle DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model userBotMapping {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  mt5_login  String   @unique
  mt5_server String
  mt5_broker String
  status     String   @default("active")
  created_at DateTime @default(now())

  @@map("user_bot_mapping")
}

enum Role {
  USER
  ADMIN
}

enum PackageType {
  STANDARD
  PREMIUM
}
