/////////////////////////////////////////////////////
// ✅ Prisma schema for tradebot-system-bot project
/////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

/////////////////////////////////////////////////////
// Database connection
/////////////////////////////////////////////////////

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////////
// Enums
/////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
}

// ✅ เพิ่ม Enum ใหม่
enum PackageType {
  STANDARD
  PREMIUM
}

/////////////////////////////////////////////////////
// Models
/////////////////////////////////////////////////////

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  role          Role           @default(USER)
  referralCode  String         @unique
  referredBy    String?
  isActive      Boolean        @default(false)
  planExpiresAt DateTime?
  balance       Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  transactions  Transaction[]

  approvedTransactions Transaction[] @relation("AdminApproval")
  binanceApiKey    String?
  binanceSecretKey String?
  
  // ✅ เพิ่ม字段ใหม่ (optional - ไม่กระทบของเดิม)
  packageType   PackageType?
  vpsId         String?

    // ✅ เพิ่ม字段สำหรับเชื่อม EA Forex
  mt5Login      String?   @unique  // MT5 Account Number
  apiKey        String?   @unique  // UUID สำหรับ EA
  eaConnectedAt DateTime?           // วันที่เชื่อม EA ครั้งแรก
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // 'upgrade' | 'bonus' | 'withdraw'
  amount      Float
  method      String   // 'binance' | 'bank' | 'system'
  accountInfo String?  // ✅ ข้อมูลบัญชีธนาคาร / Binance ID
  status      String   // 'pending' | 'approved' | 'failed'
  refUserId   String?
  txHash      String?
  qrcodeUrl   String?   // ✅ เพิ่มบรรทัดนี้
  createdAt   DateTime @default(now())
  
  approvedAt DateTime?   // ✅ วันที่อนุมัติถอน
  paidAt     DateTime?   // ✅ วันที่จ่ายเงินจริง
  paymentRef String?     // ✅ รหัสอ้างอิงธุรกรรม (เช่น TXID / เลขที่โอน)
  
  adminId     String?  // เก็บ ID ของ admin ที่อนุมัติ
  admin       User?    @relation(fields: [adminId], references: [id], name: "AdminApproval")
  
  // ✅ เพิ่ม字段ใหม่ (optional - ไม่กระทบของเดิม)
  packageType PackageType?

  // 🔗 Relationship
  user        User     @relation(fields: [userId], references: [id])
}

model BotSetting {
  id          String   @id @default(cuid())
  isRunning   Boolean  @default(false)
  lastToggle  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model userBotMapping {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  mt5_login    String   @unique
  mt5_server   String
  mt5_broker   String
  status       String   @default("active")
  created_at   DateTime @default(now())

  @@map("user_bot_mapping")
}

model licenses {
  id           Int      @id @default(autoincrement())
  api_key      String   @unique
  mt5_login    String
  email        String
  is_active    Boolean  @default(true)
  is_admin     Boolean  @default(false)
  expires_at   DateTime
  allowed_ips  String[] @default(["*"])
  magic_number Int      @default(123456)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([api_key])
  @@index([mt5_login])
  @@map("licenses")
}